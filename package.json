{
  "name": "ata-cms",
  "version": "0.1.0",
  "description": "ATA-CMS is the implementation repository for the Abadis Tejarat Arka multilingual catalog website and lightweight admin CMS.",
  "private": true,
  "license": "UNLICENSED",
  "homepage": "https://github.com/SepehrQasemi/ATA-CMS",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SepehrQasemi/ATA-CMS.git"
  },
  "bugs": {
    "url": "https://github.com/SepehrQasemi/ATA-CMS/issues"
  },
  "keywords": [
    "nextjs",
    "prisma",
    "cms",
    "catalog",
    "b2b",
    "multilingual"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "local:setup": "tsx scripts/run-local.ts --setup-only",
    "local:start": "tsx scripts/run-local.ts",
    "db:generate": "prisma generate",
    "db:push": "tsx scripts/db-push.ts",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@swc/helpers": "0.5.20",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.1",
    "jsdom": "^27.1.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
